<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Reference entitlements for Fleetarr (spec §3.3, §3.5, §7).

  These are NOT wired into the build target yet, because CloudKit/Keychain entitlements require a
  provisioning profile from an Apple Developer team. To enable iCloud sync, add
  CODE_SIGN_ENTITLEMENTS = App/Fleetarr.entitlements to the target in project.yml, open the project
  in Xcode with your team selected, and turn on the matching capabilities.
-->
<plist version="1.0">
<dict>
    <key>com.apple.developer.icloud-container-identifiers</key>
    <array>
        <string>iCloud.net.radaiko.Fleetarr</string>
    </array>
    <key>com.apple.developer.icloud-services</key>
    <array>
        <string>CloudKit</string>
    </array>
    <key>keychain-access-groups</key>
    <array>
        <string>$(AppIdentifierPrefix)net.radaiko.Fleetarr</string>
    </array>
    <!-- Phase 2/3: APNs for push notifications (spec §7). -->
    <key>aps-environment</key>
    <string>development</string>
</dict>
</plist>
